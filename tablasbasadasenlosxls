-- =====================================================
-- ESTRUCTURA DE TABLAS PARA ERP DE TALLER DE REPARACIONES
-- =====================================================

-- =====================================================
-- 1. TABLAS MAESTRAS BÁSICAS (CATÁLOGOS)
-- =====================================================

-- Tabla: plantas
CREATE TABLE plantas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(7) UNIQUE NOT NULL,
    descripcion VARCHAR(100) NOT NULL,
    activo BOOLEAN DEFAULT true,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla: areas
CREATE TABLE areas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(2) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL,
    activo BOOLEAN DEFAULT true
);

-- Tabla: categorias_material
CREATE TABLE categorias_material (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL,
    observacion VARCHAR(100),
    activo BOOLEAN DEFAULT true
);

-- Tabla: clasificaciones
CREATE TABLE clasificaciones (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(4) UNIQUE NOT NULL,
    descripcion VARCHAR(100) NOT NULL,
    activo BOOLEAN DEFAULT true
);

-- Tabla: unidades_medida
CREATE TABLE unidades_medida (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL,
    activo BOOLEAN DEFAULT true
);

-- Tabla: fabricantes
CREATE TABLE fabricantes (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    nombre VARCHAR(100) NOT NULL,
    activo BOOLEAN DEFAULT true
);

-- Tabla: monedas
CREATE TABLE monedas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(20) NOT NULL,
    simbolo VARCHAR(1),
    activo BOOLEAN DEFAULT true
);

-- =====================================================
-- 2. MÓDULO DE INVENTARIO (MATERIALES)
-- =====================================================

-- Tabla: materiales (corresponde a 1 Log - material.xlsx)
CREATE TABLE materiales (
    id SERIAL PRIMARY KEY,
    codigo_material DECIMAL(10,1),
    descripcion_compuesta TEXT,
    descripcion TEXT,
    planta_id INTEGER REFERENCES plantas(id),
    area_id INTEGER REFERENCES areas(id),
    categoria_id INTEGER REFERENCES categorias_material(id),
    clasificacion_id INTEGER REFERENCES clasificaciones(id),
    punto_reposicion DECIMAL(10,2),
    stock_maximo DECIMAL(10,2),
    unidad_medida_id INTEGER REFERENCES unidades_medida(id),
    plazo_entrega INTEGER,
    precio DECIMAL(15,4),
    moneda_id INTEGER REFERENCES monedas(id),
    fabricante_id INTEGER REFERENCES fabricantes(id),
    np VARCHAR(100),
    stock_actual DECIMAL(10,2) DEFAULT 0,
    ubicacion VARCHAR(50),
    activo BOOLEAN DEFAULT true,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla: movimientos_inventario (control de entradas/salidas)
CREATE TABLE movimientos_inventario (
    id SERIAL PRIMARY KEY,
    material_id INTEGER REFERENCES materiales(id),
    tipo_movimiento VARCHAR(10) CHECK (tipo_movimiento IN ('ENTRADA', 'SALIDA', 'AJUSTE')),
    cantidad DECIMAL(10,2) NOT NULL,
    documento_referencia VARCHAR(50),
    observacion TEXT,
    usuario VARCHAR(50),
    fecha_movimiento TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 3. MÓDULO DE ACTIVOS (EQUIPOS Y HERRAMIENTAS)
-- =====================================================

-- Tabla: sub_areas
CREATE TABLE sub_areas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(100) NOT NULL
);

-- Tabla: tipos_equipo
CREATE TABLE tipos_equipo (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: criticidades
CREATE TABLE criticidades (
    id SERIAL PRIMARY KEY,
    codigo DECIMAL(2,1) UNIQUE NOT NULL,
    descripcion VARCHAR(20) NOT NULL
);

-- Tabla: equipos (corresponde a 2 Mant - equipos y Herramientos.xlsx)
CREATE TABLE equipos (
    id SERIAL PRIMARY KEY,
    usuario VARCHAR(50),
    equipo VARCHAR(100),
    descripcion TEXT,
    status VARCHAR(3) CHECK (status IN ('OPE', 'INO', 'REP', 'STD', 'BAJ')),
    area_id INTEGER REFERENCES areas(id),
    sub_area_id INTEGER REFERENCES sub_areas(id),
    tipo_id INTEGER REFERENCES tipos_equipo(id),
    fecha_inicio DATE,
    fecha_fabricacion DATE,
    fabricante_id INTEGER REFERENCES fabricantes(id),
    modelo VARCHAR(100),
    nserie VARCHAR(100),
    np VARCHAR(100),
    capacidad DECIMAL(10,2),
    unidad_medida_id INTEGER REFERENCES unidades_medida(id),
    texto TEXT,
    planta_id INTEGER REFERENCES plantas(id),
    criticidad_id INTEGER REFERENCES criticidades(id)
);

-- =====================================================
-- 4. MÓDULO DE COMPONENTES (COD REP)
-- =====================================================

-- Tabla: tipos_componente (de 5. Cod Rep.xlsx - Tipo)
CREATE TABLE tipos_componente (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: categorias_flota (de 5. Cod Rep.xlsx - Categoría)
CREATE TABLE categorias_flota (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: flotas (modelos de máquinas)
CREATE TABLE flotas (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    descripcion VARCHAR(100),
    categoria_id INTEGER REFERENCES categorias_flota(id)
);

-- Tabla: posiciones
CREATE TABLE posiciones (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(3) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: componentes_maestros (corresponde a 5. Cod Rep.xlsx - Cod Rep)
CREATE TABLE componentes_maestros (
    id SERIAL PRIMARY KEY,
    codigo_rep VARCHAR(50) UNIQUE,
    usuario VARCHAR(50),
    descripcion VARCHAR(200) NOT NULL,
    tipo_componente_id INTEGER REFERENCES tipos_componente(id),
    categoria_flota_id INTEGER REFERENCES categorias_flota(id),
    flota_id INTEGER REFERENCES flotas(id),
    fabricante_id INTEGER REFERENCES fabricantes(id),
    np VARCHAR(100),
    posicion_id INTEGER REFERENCES posiciones(id),
    precio_referencia DECIMAL(15,4),
    activo BOOLEAN DEFAULT true
);

-- =====================================================
-- 5. MÓDULO DE LISTAS DE MATERIALES (BOM)
-- =====================================================

-- Tabla: listas_materiales (corresponde a 4. Log prod - Task list materiales.xlsx)
CREATE TABLE listas_materiales (
    id SERIAL PRIMARY KEY,
    usuario VARCHAR(50),
    actividad VARCHAR(100),
    cod_rep VARCHAR(50),
    np_cod1 VARCHAR(100),
    np_cod2 VARCHAR(100),
    id_tubo VARCHAR(50),
    od_vas VARCHAR(50),
    descripcion TEXT,
    item INTEGER,
    tipo VARCHAR(3) CHECK (tipo IN ('MAC', 'CAD', 'SER')),
    material_id INTEGER REFERENCES materiales(id),
    requerimiento DECIMAL(10,2),
    ref_descripcion VARCHAR(200),
    np VARCHAR(100),
    texto TEXT,
    precio DECIMAL(15,4),
    componente_maestro_id INTEGER REFERENCES componentes_maestros(id)
);

CREATE INDEX idx_listas_materiales_cod_rep ON listas_materiales(cod_rep);

-- =====================================================
-- 6. MÓDULO DE ESTRATEGIAS DE MANTENIMIENTO
-- =====================================================

-- Tabla: tipo_estrategias
CREATE TABLE tipo_estrategias (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(2) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: estrategias (corresponde a 3. Todos - Estrategias.xlsx)
CREATE TABLE estrategias (
    id SERIAL PRIMARY KEY,
    usuario VARCHAR(50),
    estrategia VARCHAR(200),
    area_id INTEGER REFERENCES areas(id),
    equipo VARCHAR(100),
    actividad TEXT,
    frecuencia DECIMAL(10,2),
    unidad_medida_id INTEGER REFERENCES unidades_medida(id),
    descripcion_estrategia TEXT,
    tipo_estrategia_id INTEGER REFERENCES tipo_estrategias(id),
    status VARCHAR(2) CHECK (status IN ('AC', 'PR', 'EL'))
);

-- =====================================================
-- 7. MÓDULO DE ÓRDENES DE TRABAJO (OT)
-- =====================================================

-- Tabla: clientes (de 6. Ots.xlsx - Cliente)
CREATE TABLE clientes (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    nombre_completo VARCHAR(200) NOT NULL,
    ruc VARCHAR(11),
    direccion TEXT,
    telefono VARCHAR(20),
    contacto VARCHAR(100),
    activo BOOLEAN DEFAULT true
);

-- Tablas de estado para OT
CREATE TABLE ot_status (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL
);

CREATE TABLE recursos_status (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL
);

CREATE TABLE taller_status (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL
);

-- Tabla: atencion_reparacion (tipos de atención)
CREATE TABLE atencion_reparacion (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    descripcion TEXT
);

-- Tabla: tipo_reparacion
CREATE TABLE tipo_reparacion (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    descripcion TEXT
);

-- Tabla: tipo_garantia
CREATE TABLE tipo_garantia (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(20) UNIQUE NOT NULL,
    descripcion TEXT
);

-- Tabla: prioridades_atencion
CREATE TABLE prioridades_atencion (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(5) UNIQUE NOT NULL,
    descripcion VARCHAR(50) NOT NULL
);

-- Tabla: ordenes_trabajo (corresponde a 6. Ots.xlsx - Sheet1)
CREATE TABLE ordenes_trabajo (
    id SERIAL PRIMARY KEY,
    ot_numero VARCHAR(50) UNIQUE,
    cliente_id INTEGER REFERENCES clientes(id),
    estrategia BOOLEAN DEFAULT false,
    cod_rep_id INTEGER REFERENCES componentes_maestros(id),
    tipo VARCHAR(50),
    np VARCHAR(100),
    descripcion TEXT,
    fabricante_id INTEGER REFERENCES fabricantes(id),
    flota_id INTEGER REFERENCES flotas(id),
    posicion_id INTEGER REFERENCES posiciones(id),
    equipo VARCHAR(100),
    ns VARCHAR(100),
    plaqueteo VARCHAR(50),
    wo_cliente VARCHAR(100),
    po_cliente VARCHAR(100),
    id_viajero VARCHAR(100),
    guia_remision_llegada VARCHAR(100),
    empresa_entrega VARCHAR(100),
    fecha_recepcion DATE,
    pcr DECIMAL(10,2),
    horas_trabajadas DECIMAL(10,2) DEFAULT 0,
    porcentaje_pcr DECIMAL(5,2) GENERATED ALWAYS AS (CASE WHEN pcr > 0 THEN (horas_trabajadas / pcr) * 100 ELSE 0 END) STORED,
    garantia BOOLEAN DEFAULT false,
    atencion_reparacion_id INTEGER REFERENCES atencion_reparacion(id),
    tipo_reparacion_id INTEGER REFERENCES tipo_reparacion(id),
    tipo_garantia_id INTEGER REFERENCES tipo_garantia(id),
    prioridad_id INTEGER REFERENCES prioridades_atencion(id),
    contrato_dias INTEGER,
    base_metalica BOOLEAN DEFAULT false,
    comentarios TEXT,
    fecha_requerimiento_cliente DATE,
    ot_status_id INTEGER REFERENCES ot_status(id),
    recursos_status_id INTEGER REFERENCES recursos_status(id),
    taller_status_id INTEGER REFERENCES taller_status(id),
    created_by VARCHAR(50),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 8. PLANIFICACIÓN DE TALLER (RUTAS DE TRABAJO)
-- =====================================================

-- Tabla: tipo_operacion (de Tablas de planificacion.xlsx)
CREATE TABLE tipo_operacion (
    id SERIAL PRIMARY KEY,
    codigo VARCHAR(10) UNIQUE NOT NULL,
    descripcion VARCHAR(100) NOT NULL,
    area_trabajo VARCHAR(20)
);

-- Tabla: operaciones_estandar
CREATE TABLE operaciones_estandar (
    id SERIAL PRIMARY KEY,
    tipo_operacion_id INTEGER REFERENCES tipo_operacion(id),
    estandar BOOLEAN DEFAULT true,
    descripcion_completa TEXT,
    horas_estimadas DECIMAL(8,2),
    especialidad VARCHAR(50)
);

-- Tabla: rutas_trabajo (operaciones planificadas para una OT)
CREATE TABLE rutas_trabajo (
    id SERIAL PRIMARY KEY,
    orden_trabajo_id INTEGER REFERENCES ordenes_trabajo(id),
    operacion_id INTEGER REFERENCES tipo_operacion(id),
    secuencia INTEGER,
    descripcion TEXT,
    horas_estimadas DECIMAL(8,2),
    horas_reales DECIMAL(8,2),
    fecha_inicio DATE,
    fecha_fin DATE,
    responsable VARCHAR(100),
    estado VARCHAR(20) DEFAULT 'PENDIENTE'
);

-- =====================================================
-- 9. TABLAS DE RELACIÓN Y LOGS
-- =====================================================

-- Tabla: materiales_por_ot (materiales solicitados para una OT)
CREATE TABLE materiales_por_ot (
    id SERIAL PRIMARY KEY,
    orden_trabajo_id INTEGER REFERENCES ordenes_trabajo(id),
    material_id INTEGER REFERENCES materiales(id),
    cantidad_requerida DECIMAL(10,2),
    cantidad_entregada DECIMAL(10,2) DEFAULT 0,
    precio_unitario DECIMAL(15,4),
    estado VARCHAR(20) DEFAULT 'PENDIENTE',
    fecha_requerimiento DATE,
    fecha_entrega DATE,
    observacion TEXT
);

-- Tabla: historial_estados_ot (tracking de cambios de estado)
CREATE TABLE historial_estados_ot (
    id SERIAL PRIMARY KEY,
    orden_trabajo_id INTEGER REFERENCES ordenes_trabajo(id),
    ot_status_id INTEGER REFERENCES ot_status(id),
    recursos_status_id INTEGER REFERENCES recursos_status(id),
    taller_status_id INTEGER REFERENCES taller_status(id),
    usuario VARCHAR(50),
    comentario TEXT,
    fecha_cambio TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

